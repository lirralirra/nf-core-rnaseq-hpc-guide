// SLURM executor settings for nf-core/rnaseq on Phoenix.
//
// Nextflow itself submits each pipeline step as a separate SLURM job. To avoid
// overloading the shared HPC scheduler, this template limits how many jobs can
// be active and how fast they are submitted. Conservative, beginner-friendly
// defaults are used; raise them only if your allocation can take it.

process {
    executor = 'slurm'
    maxForks = 8                  // max concurrent instances of any single process
    // queue = 'PARTITION'         // set to a valid Phoenix partition if one is required
    // clusterOptions = '--account=ACCOUNT'   // set if Phoenix requires an account
}

executor {
    queueSize       = 20          // max jobs Nextflow keeps queued/running at once
    submitRateLimit = '10/1min'   // throttle how fast jobs are submitted to SLURM
}
